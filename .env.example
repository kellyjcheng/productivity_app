# CLAUDE CODE INSTRUCTIONS — .env.example
# This file documents all required environment variables.
# Copy to .env and fill in your values. NEVER commit .env to git.

# OpenWeatherMap API Key (free at openweathermap.org)
VITE_OWM_API_KEY=open_weather_map_api_key_here

# Your coordinates for weather
VITE_LATITUDE=000.0000
VITE_LONGITUDE=000.0000

# 'forecast' (free tier) or 'onecall' (paid tier)
VITE_OWM_TIER=forecast

# Temperature unit: 'imperial' (°F) or 'metric' (°C)
VITE_TEMP_UNIT=imperial

# GNews API Key (free at gnews.io)
VITE_GNEWS_API_KEY=gnews_api_key_here

# Client ID for Google OAuth (get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Finnhub API Key (free at finnhub.io) — real-time stock quotes and sparklines
VITE_YAHOO_FINANCE_API_KEY=your_finnhub_key_here
